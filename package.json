{
  "name": "git-commit-assist",
  "displayName": "Git Commit Assist",
  "description": "Review staged git changes and get code improvement suggestions powered by Context7 documentation",
  "version": "0.0.1",
  "engines": {
    "vscode": "^1.109.0"
  },
  "categories": [
    "Linters",
    "Other"
  ],
  "activationEvents": [],
  "main": "./out/extension.js",
  "contributes": {
    "commands": [
      {
        "command": "git-commit-assist.reviewDiff",
        "title": "Review Staged Changes",
        "category": "Git Commit Assist"
      }
    ],
    "viewsContainers": {
      "activitybar": [
        {
          "id": "git-commit-assist",
          "title": "Git Commit Assist",
          "icon": "resources/icon.svg"
        }
      ]
    },
    "views": {
      "git-commit-assist": [
        {
          "type": "webview",
          "id": "git-commit-assist.sidebar",
          "name": "Git Commit Assist"
        }
      ]
    }
  },
  "scripts": {
    "vscode:prepublish": "npm run compile",
    "compile": "tsc -p ./ && tsc -p tsconfig.webview.json && npm run copy-webview-assets",
    "copy-webview-assets": "cp src/webview/sidebar.html src/webview/sidebar.css out/webview/",
    "watch": "tsc -watch -p ./",
    "pretest": "npm run compile && npm run lint",
    "lint": "eslint src",
    "test": "vscode-test"
  },
  "devDependencies": {
    "@types/vscode": "^1.109.0",
    "@types/mocha": "^10.0.10",
    "@types/node": "22.x",
    "typescript-eslint": "^8.56.1",
    "eslint": "^9.39.3",
    "typescript": "^5.9.3",
    "@vscode/test-cli": "^0.0.12",
    "@vscode/test-electron": "^2.5.2"
  }
}
